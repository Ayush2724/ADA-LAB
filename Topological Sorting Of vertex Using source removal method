#include <stdio.h>

int main() {
    int n, a[10][10], indeg[10], i, j, k, count = 0;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");
    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d", &a[i][j]);

    while(count < n) {
        for(i=0;i<n;i++) {
            indeg[i] = 0;
            for(j=0;j<n;j++)
                indeg[i] += a[j][i];
        }

        for(i=0;i<n;i++) {
            if(indeg[i] == 0) {
                printf("%d ", i);
                count++;
                indeg[i] = -1;

                for(k=0;k<n;k++)
                    a[i][k] = 0;
                for(k=0;k<n;k++)
                    a[k][i] = -1;
                break;
            }
        }

        if(i == n) {
            printf("\nCycle exists");
            return 0;
        }
    }

    return 0;
}
