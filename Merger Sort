#include <stdio.h>      // For input/output functions
#include <stdlib.h>     // For rand() and srand()
#include <time.h>       // For clock() and time()

#define MAX 50000        // Maximum number of elements

int arr[MAX], temp[MAX];   // Global arrays for storing numbers

/* Function to merge two sorted subarrays */
void merge(int low, int mid, int high)
{
    int i = low;       // Starting index of first half
    int j = mid + 1;   // Starting index of second half
    int k = low;       // Index for temporary array

    // Compare elements from both halves and store the smaller one
    while (i <= mid && j <= high)
    {
        if (arr[i] < arr[j])
            temp[k++] = arr[i++];   // Copy from first half
        else
            temp[k++] = arr[j++];   // Copy from second half
    }

    // Copy remaining elements of first half (if any)
    while (i <= mid)
        temp[k++] = arr[i++];

    // Copy remaining elements of second half (if any)
    while (j <= high)
        temp[k++] = arr[j++];

    // Copy sorted elements back to original array
    for (i = low; i <= high; i++)
        arr[i] = temp[i];
}

/* Recursive function to divide the array and sort */
void mergesort(int low, int high)
{
    if (low < high)
    {
        int mid = (low + high) / 2;

        // Sort first half
        mergesort(low, mid);

        // Sort second half
        mergesort(mid + 1, high);

        // Merge both halves
        merge(low, mid, high);
    }
}

int main()
{
    int n, i;
    clock_t start, end;
    double time_taken;

    srand(time(NULL));

    printf("N\tTime Taken (seconds)\n");


    for (n = 10000; n <= 50000; n += 10000)
    {

        for (i = 0; i < n; i++)
        {
            arr[i] = rand() % 10000;
        }

        // Start measuring time
        start = clock();


        mergesort(0, n - 1);


        end = clock();


        time_taken = (double)(end - start) / CLOCKS_PER_SEC;

        printf("%d\t%.10f\n", n, time_taken);
    }

    return 0;
}

