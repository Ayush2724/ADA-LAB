#include <stdlib.h>

int findTargetSumWays(int* nums, int numsSize, int target) {

    int sum = 0;

    for (int i = 0; i < numsSize; i++) {
        sum += nums[i];
    }

    if (abs(target) > sum || (sum + target) % 2)
        return 0;

    int S = (sum + target) / 2;

    int *dp = calloc(S + 1, sizeof(int));

    dp[0] = 1;

    for (int i = 0; i < numsSize; i++) {

        for (int j = S; j >= nums[i]; j--) {

            dp[j] += dp[j - nums[i]];
        }
    }

    int ans = dp[S];

    free(dp);

    return ans;
}
