#include <stdio.h>

#define MAX 20
#define INF 999

int main() {
    int n, cost[MAX][MAX];
    int visited[MAX] = {0};
    int i, j, u, v, min;
    int ne = 1;          // number of edges
    int mincost = 0;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter the cost matrix:\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            scanf("%d", &cost[i][j]);

            // If no edge, replace 0 with INF
            if(cost[i][j] == 0)
                cost[i][j] = INF;
        }
    }

    visited[0] = 1;   // Start from vertex 0

    printf("\nEdges in MST:\n");

    while(ne < n) {
        min = INF;

        for(i = 0; i < n; i++) {
            if(visited[i] == 1) {
                for(j = 0; j < n; j++) {
                    if(visited[j] == 0 && cost[i][j] < min) {
                        min = cost[i][j];
                        u = i;
                        v = j;
                    }
                }
            }
        }

        printf("%d -> %d = %d\n", u, v, min);

        visited[v] = 1;
        mincost += min;

        cost[u][v] = cost[v][u] = INF; // avoid reuse
        ne++;
    }

    printf("\nMinimum cost = %d\n", mincost);

    return 0;
}





